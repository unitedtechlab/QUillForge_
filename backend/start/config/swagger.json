{
  "openapi": "3.0.0",
  "info": {
    "title": "QuillForge REST API Documentation",
    "version": "1.0.0",
    "description": "Comprehensive API specification sheet for QuillForge \u2014 a developer-themed retro blogging platform."
  },
  "servers": [
    {
      "url": "http://localhost:8102/api/v1",
      "description": "Local Development Server"
    },
    {
      "url": "https://api.quillforge.unitedtechlab.com/api/v1",
      "description": "Production Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "accessToken",
        "description": "JWT authentication cookie containing access details."
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "example": "65893a72cb123e4567890def"
          },
          "username": {
            "type": "string",
            "example": "hacker_writer"
          },
          "email": {
            "type": "string",
            "example": "writer@gmail.com"
          },
          "role": {
            "type": "string",
            "enum": [
              "user",
              "admin"
            ],
            "example": "user"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Blog": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "example": "65893b82cb123e4567890abc"
          },
          "title": {
            "type": "string",
            "example": "Mastering Mongoose Aggregations"
          },
          "slug": {
            "type": "string",
            "example": "mastering-mongoose-aggregations"
          },
          "excerpt": {
            "type": "string",
            "example": "Learn how to write performant pipelines."
          },
          "content": {
            "type": "string",
            "example": "<p>MongoDB Aggregation framework is powerful...</p>"
          },
          "author": {
            "type": "string",
            "description": "User ID of the author",
            "example": "65893a72cb123e4567890def"
          },
          "isPublished": {
            "type": "boolean",
            "example": true
          },
          "featuredImage": {
            "type": "string",
            "example": "https://res.cloudinary.com/demo/image/upload/v1/featured.png"
          },
          "views": {
            "type": "integer",
            "example": 42
          },
          "likes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "65893a72cb123e4567890def"
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "paths": {
    "/users/register": {
      "post": {
        "summary": "Register a new user",
        "description": "Creates a new user profile using credentials. Only Gmail/Google workspace accounts are allowed.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "username",
                  "email",
                  "password"
                ],
                "properties": {
                  "username": {
                    "type": "string",
                    "example": "new_writer"
                  },
                  "email": {
                    "type": "string",
                    "example": "new_writer@gmail.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "SecurePass123!"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "User registered successfully"
                    },
                    "data": {
                      "$ref": "#/components/schemas/User"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid input or email already registered"
          }
        }
      }
    },
    "/users/login": {
      "post": {
        "summary": "Login user and generate cookie",
        "description": "Authenticates user credentials and returns a secure HTTPOnly cookie with JWT token.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "example": "writer@gmail.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "SecurePass123!"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "headers": {
              "Set-Cookie": {
                "schema": {
                  "type": "string",
                  "example": "accessToken=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...; Path=/; HttpOnly; Secure"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "user": {
                          "$ref": "#/components/schemas/User"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid credentials"
          }
        }
      }
    },
    "/users/validate-email": {
      "get": {
        "summary": "Validate Gmail existence",
        "description": "Validates email formatting and checks whether the Google account exists on Google's mail servers.",
        "parameters": [
          {
            "name": "email",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "example": "writer@gmail.com"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Validation results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "isValid": {
                          "type": "boolean",
                          "example": true
                        },
                        "exists": {
                          "type": "boolean",
                          "example": true
                        },
                        "isGoogle": {
                          "type": "boolean",
                          "example": true
                        },
                        "reason": {
                          "type": "string",
                          "example": "Gmail account exists on Google"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/users/current-user": {
      "get": {
        "summary": "Get authenticated user profile",
        "description": "Retrieves metadata of the currently signed-in user.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "User profile details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "$ref": "#/components/schemas/User"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Cookie missing or invalid"
          }
        }
      }
    },
    "/users/logout": {
      "post": {
        "summary": "Logout user",
        "description": "Clears the JWT authentication access cookie.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Logout successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Logged out successfully"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/users/google": {
      "get": {
        "summary": "Initiate Google OAuth2 authentication flow",
        "description": "Redirects browser to Google Account selection and authorization screen.",
        "responses": {
          "302": {
            "description": "Redirects to Google accounts gateway"
          }
        }
      }
    },
    "/users/google/callback": {
      "get": {
        "summary": "Google authentication callback target",
        "description": "Receives redirection authorization code from Google, authenticates user, sets cookie, and redirects user to landing dashboard.",
        "parameters": [
          {
            "name": "code",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "302": {
            "description": "Sets cookie and redirects to dashboard/admin"
          }
        }
      }
    },
    "/blogs/upload": {
      "post": {
        "summary": "Upload image to Cloudinary",
        "description": "Uploads an image file to Cloudinary cloud hosting using a multipart form file stream.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "image"
                ],
                "properties": {
                  "image": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Image uploaded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "url": {
                      "type": "string",
                      "example": "https://res.cloudinary.com/demo/image/upload/v1/featured.png"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/blogs": {
      "get": {
        "summary": "Fetch all blogs",
        "description": "Retrieves list of all draft and published blog posts with populated author info.",
        "responses": {
          "200": {
            "description": "List of blogs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Blog"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create new blog post",
        "description": "Saves a new blog draft or published post linked to the signed-in user.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title",
                  "content"
                ],
                "properties": {
                  "title": {
                    "type": "string",
                    "example": "Creating clean APIs"
                  },
                  "content": {
                    "type": "string",
                    "example": "<p>Content markdown...</p>"
                  },
                  "excerpt": {
                    "type": "string",
                    "example": "Brief overview..."
                  },
                  "isPublished": {
                    "type": "boolean",
                    "example": true
                  },
                  "featuredImage": {
                    "type": "string",
                    "example": "https://res.cloudinary.com/image.png"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Blog created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "$ref": "#/components/schemas/Blog"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/blogs/{id}": {
      "get": {
        "summary": "Retrieve single blog by ID",
        "description": "Fetches populated blog attributes.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "example": "65893b82cb123e4567890abc"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Blog details object",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "$ref": "#/components/schemas/Blog"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Blog not found"
          }
        }
      },
      "put": {
        "summary": "Update existing blog post",
        "description": "Edits title, content, status, excerpt, or image of a blog. Requires author ownership or Admin role.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "example": "65893b82cb123e4567890abc"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "example": "Updated API design guidelines"
                  },
                  "content": {
                    "type": "string",
                    "example": "New revised text body..."
                  },
                  "isPublished": {
                    "type": "boolean",
                    "example": false
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Blog updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "$ref": "#/components/schemas/Blog"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete blog post",
        "description": "Deletes a post. Requires ownership or Admin role.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "example": "65893b82cb123e4567890abc"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Delete success status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Blog deleted successfully"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/blogs/{id}/view": {
      "patch": {
        "summary": "Increment read count atomically",
        "description": "Performs fire-and-forget view count increment inside blog details screen.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "example": "65893b82cb123e4567890abc"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success views counter state",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "views": {
                      "type": "integer",
                      "example": 43
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/blogs/{id}/like": {
      "patch": {
        "summary": "Toggle user like on post",
        "description": "Adds or removes user ID from blog likes array and returns toggle status.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "example": "65893b82cb123e4567890abc"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "New like details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "likesCount": {
                      "type": "integer",
                      "example": 14
                    },
                    "liked": {
                      "type": "boolean",
                      "example": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/blogs/ai-generate": {
      "post": {
        "summary": "Generate a blog post using AI (Gemini 2.5 Flash)",
        "tags": [
          "AI"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "subject",
                  "tone",
                  "blogType"
                ],
                "properties": {
                  "subject": {
                    "type": "string",
                    "maxLength": 300
                  },
                  "tone": {
                    "type": "string",
                    "enum": [
                      "Professional",
                      "Casual",
                      "Humorous",
                      "Enthusiastic",
                      "Academic"
                    ]
                  },
                  "blogType": {
                    "type": "string",
                    "enum": [
                      "Technical",
                      "Tutorial",
                      "Case Study",
                      "Narrative",
                      "Creative",
                      "Opinion"
                    ]
                  },
                  "context": {
                    "type": "string",
                    "maxLength": 2000
                  },
                  "savePreset": {
                    "type": "boolean"
                  },
                  "presetName": {
                    "type": "string",
                    "maxLength": 100
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Blog generated successfully"
          },
          "400": {
            "description": "Missing required fields or input too long"
          },
          "403": {
            "description": "Free plan limit reached"
          },
          "429": {
            "description": "Rate limited (1 request per 15 seconds)"
          },
          "500": {
            "description": "AI generation failed"
          }
        }
      }
    },
    "/blogs/ai-presets": {
      "get": {
        "summary": "Get the current user's saved AI writing presets",
        "tags": [
          "AI"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Presets fetched successfully"
          }
        }
      }
    },
    "/blogs/ai-presets/{id}": {
      "delete": {
        "summary": "Delete a saved AI writing preset",
        "tags": [
          "AI"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Preset deleted successfully"
          },
          "404": {
            "description": "Preset not found"
          }
        }
      }
    }
  }
}